<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {{ "Dhruti Davey" | formatName }}</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    {% include "nav.njk" %}

    <h1>{{ title }}</h1>
  </header>

  <main>
    {% for tag in tags %}
      <span class="tag">{{ tag }}</span>
    {% endfor %}
    {{ content | safe }}
  </main>

  <footer>
    <p>&copy; 2026 {{ "Dhruti Davey" | formatName }}. Built with 11ty.</p>
  </footer>
</body>
</html>
