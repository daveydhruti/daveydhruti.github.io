<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {{ "Dhruti Davey" | formatName }}</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    {% include "nav.njk" %}
    <h1>{{ title }}</h1>
    <section class="intro">
      <p>{{ intro | safe }}</p>
      {% if background %}
        <p>{{ background | safe }}</p>
      {% endif %}
    </section>
  </header>

  <main>
    {% if research-interests %}
      <section class="research-interests">
        <h2>Research Interests</h2>
        <p>{{ researchInterests.intro }}</p>
        <ul>
          {% for area in researchInterests.areas %}
          <li><strong>{{ area.name }}:</strong> {{ area.desc }}</li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}
    
    <section class="education">
      <h2>Education</h2>
      {% for edu in education %}
      <article>
        <h3>{{ edu.degree }} {% if edu.year %}({{ edu.year }}){% endif %}</h3>
        <p>{{ edu.school }}, {{ edu.period }}</p>
        {% if edu.thesis %}<p><em>Thesis: "{{ edu.thesis }}"</em></p>{% endif %}
        {% if edu.grade %}<p><strong>Grade:</strong> {{ edu.grade }}</p>{% endif %}
        {% if edu.modules %}
        <p><strong>Modules:</strong>
        <div class="modules-container">
          {% for term in edu.modules %}
          <div class="term">
            <h4>
              {% if term.year and term.semester %}
                {{ term.year }} &middot; {{ term.semester }}
              {% elif term.semester %}
                {{ term.semester }}
              {% elif term.year %}
                {{ term.year }}
              {% else %}
                Term
              {% endif %}
            </h4>
            <ul>
              {% for module in term.modules %}
              <li>{{ module }}</li>
              {% endfor %}
            </ul>
          </div>
          {% endfor %}
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </section>

    <section class="experience">
      <h2>Experience</h2>
      {% for job in experience %}
      <article>
        <h3>{{ job.role }}</h3>
        <p>{{ job.org }}, {{ job.period }}</p>
      </article>
      {% endfor %}
    </section>

    {% if awards %}
      <section class="awards">
        <h2>Honors &amp; Awards</h2>
        <ul>
          {% for award in awards %}
          <li>{{ award }}</li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}
  </main>

  <footer>
    <p>&copy; 2026 {{ "Dhruti Davey" | formatName }}. Built with 11ty.</p>
  </footer>
</body>
</html>
