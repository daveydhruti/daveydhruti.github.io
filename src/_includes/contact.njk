<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - Dhruti Davey</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    {% include "nav.njk" %}

    <h1>{{ title }}</h1>
  </header>

  <main>
    <section class="intro">
      <p>{{ intro }}</p>
    </section>

    <section class="contact-info">
      <ul>
        {% if email %}
          <li><strong>Email:</strong> <a href="mailto:{{ email }}">{{ email }}</a></li>
        {% endif %}
        {% if social.gitlab %}
          <li><strong>GitLab:</strong> <a href="{{ social.gitlab.url }}">{{ social.gitlab.handle }}</a></li>
        {% endif %}
        {% if social.scholar %}
          <li><strong>Google Scholar:</strong> <a href="{{ social.scholar.url }}">{{ social.scholar.name }}</a></li>
        {% endif %}
        {% if social.linkedin %}
          <li><strong>LinkedIn:</strong> <a href="{{ social.linkedin.url }}">{{ social.linkedin.name }}</a></li>
        {% endif %}
      </ul>
    </section>

  </main>
  <footer>
    <p>&copy; 2026 Dhruti Davey. Built with 11ty.</p>
  </footer>
</body>
</html>
