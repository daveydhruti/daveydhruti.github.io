<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {{ "Dhruti Davey" | formatName }}</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    {% include "nav.njk" %}
    
    <h1>{{ title }}</h1>
    <section class="intro">
      <p>{{ intro }}</p>
    </section>
  </header>

  <main>
    <section class="list">
      <ul>
        {% for f in following %}
          <li><a href="{{ f.url }}">{{ f.name }}</a></li>
        {% endfor %}
      </ul>
    </section>

  </main>
  <footer>
    <p>&copy; 2026 {{ "Dhruti Davey" | formatName }}. Built with 11ty.</p>
  </footer>
</body>
</html>
