<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - Dhruti Davey</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    {% include "nav.njk" %}

    <h1>{{ title }}</h1>
    {% if description %}
    <p>{{ description }}</p>
    {% endif %}
  </header>

  <main>
    <section class="intro">
      <p>{{ intro }}</p>
    </section>

    <section class="projects">
      <h2>Projects</h2>
      {% for pub in projects %}
        <article id="{{ pub.id }}">
          <h3>{{ pub.title }}</h3>
          <p class="authors">{{ pub.authors | join(', ') }}</p>
          <p class="venue"><em>{{ pub.venue }}</em></p>
          <p class="description">{{ pub.description }}</p>
          <p class="links">
            {% if pub.links.pdf %}<a href="{{ pub.links.pdf }}">[PDF]</a>{% endif %}
            {% if pub.links.code %}<a href="{{ pub.links.code }}">[Code]</a>{% endif %}
            {% if pub.links.slides %}<a href="{{ pub.links.slides }}">[Slides]</a>{% endif %}
            {% if pub.links.poster %}<a href="{{ pub.links.poster }}">[Poster]</a>{% endif %}
          </p>
          {% if pub.tags %}
          <div class="tags">
            {% for tag in pub.tags %}
            <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </article>
      {% endfor %}
    </section>

    {% if publications %}
      <section class="publications">
        <h2>Publications</h2>
        {% for pub in publications %}
        <article id="{{ pub.id }}">
          <h3>{{ pub.title }}</h3>
          <p class="authors">{{ pub.authors | join(', ') }}</p>
          <p class="venue"><em>{{ pub.venue }}</em></p>
          <p class="description">{{ pub.description }}</p>
          <p class="links">
            {% if pub.links.pdf %}<a href="{{ pub.links.pdf }}">[PDF]</a>{% endif %}
            {% if pub.links.code %}<a href="{{ pub.links.code }}">[Code]</a>{% endif %}
            {% if pub.links.slides %}<a href="{{ pub.links.slides }}">[Slides]</a>{% endif %}
            {% if pub.links.poster %}<a href="{{ pub.links.poster }}">[Poster]</a>{% endif %}
          </p>
          {% if pub.tags %}
          <div class="tags">
            {% for tag in pub.tags %}
            <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </article>
        {% endfor %}
      </section>
    {% endif %}

    {% if workInProgress %}
    <section class="work-in-progress">
      <h2>Work in Progress</h2>
      <ul>
        {% for project in workInProgress %}
        <li>
          <strong>{{ project.title }}</strong> 
          <p class="description">{{ project.description }}</p>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  </main>

  <footer>
    <p>&copy; 2026 Dhruti Davey. Built with 11ty.</p>
  </footer>
</body>
</html>
