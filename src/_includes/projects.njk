<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {{ "Dhruti Davey" | formatName }}</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    {% include "nav.njk" %}

    <h1>{{ title }}</h1>
    <section class="intro">
      {% if description %}
        <p>{{ description }}</p>
      {% endif %}
    </section>
  </header>

  <main>
    <section class="intro">
      <p>{{ intro }}</p>
    </section>

    <section class="projects">
      {% for proj in selected_projects %}
        <article id="{{ proj.id }}">
          {% if proj.blog %}        
            <h3><a href="{{ proj.blog }}">{{ proj.title }}</a></h3>
          {% else %}
            <h3>{{ proj.title }}</h3>
          {% endif %}
          <p class="authors">{{ proj.authors | formatAuthors }}</p>
          <p class="venue"><em>{{ proj.venue }}</em></p>
          <div class="projects-description">
          {% for d in proj.description %}
            <ul>
              <li>{{ d }}</li>
            </ul>
          {% endfor %}
          </div>
          <p class="links">
            {% if proj.links.pdf %}<a href="{{ proj.links.pdf }}">[PDF]</a>{% endif %}
            {% if proj.links.code %}<a href="{{ proj.links.code }}">[Code]</a>{% endif %}
            {% if proj.links.slides %}<a href="{{ proj.links.slides }}">[Slides]</a>{% endif %}
            {% if proj.links.poster %}<a href="{{ proj.links.poster }}">[Poster]</a>{% endif %}
          </p>
          {% if proj.tags %}
          <div class="tags">
            {% for tag in proj.tags %}
            <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </article>
      {% endfor %}
    </section>

    {% if publications %}
      <section class="publications">
        <h2>Publications</h2>
        {% for pub in publications %}
        <article id="{{ pub.id }}">
          <h3>{{ pub.title }}</h3>
          <p class="authors">{{ pub.authors | formatAuthors }}</p>
          <p class="venue"><em>{{ pub.venue }}</em></p>
          <div class="projects-description">
            {% for d in pub.description %}
              <ul>
                <li>{{ d }}</li>
              </ul>
            {% endfor %}
          </div>          
          <p class="links">
            {% if pub.links.pdf %}<a href="{{ pub.links.pdf }}">[PDF]</a>{% endif %}
            {% if pub.links.code %}<a href="{{ pub.links.code }}">[Code]</a>{% endif %}
            {% if pub.links.slides %}<a href="{{ pub.links.slides }}">[Slides]</a>{% endif %}
            {% if pub.links.poster %}<a href="{{ pub.links.poster }}">[Poster]</a>{% endif %}
          </p>
          {% if pub.tags %}
          <div class="tags">
            {% for tag in pub.tags %}
            <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </article>
        {% endfor %}
      </section>
    {% endif %}
    
    {% if projects %}
      <section class="projects">
        {% for proj in projects %}
          {% if proj.projects %}
            <h2>{{ proj.semester }}</h2>
            {% for p in proj.projects %}
              <article id="{{ p.id }}">
                <h3>{{ p.title }}</h3>
                <p class="venue"><em>{{ p.venue }}</em></p>
                <div class="projects-description">
                  {% for d in p.description %}
                    <ul>
                      <li>{{ d }}</li>
                    </ul>
                  {% endfor %}
                </div> 
                <p class="links">
                  {% if p.links.pdf %}<a href="{{ p.links.pdf }}">[PDF]</a>{% endif %}
                  {% if p.links.code %}<a href="{{ p.links.code }}">[Code]</a>{% endif %}
                  {% if p.links.slides %}<a href="{{ p.links.slides }}">[Slides]</a>{% endif %}
                  {% if p.links.poster %}<a href="{{ p.links.poster }}">[Poster]</a>{% endif %}
                </p>
                {% if p.tags %}
                  <div class="tags">
                    {% for tag in p.tags %}
                    <span class="tag">{{ tag }}</span>
                    {% endfor %}
                  </div>
                {% endif %}
              </article>
            {% endfor %}
          {% endif %}
        {% endfor %}
      </section>
    {% endif %}

    {% if workInProgress %}
    <section class="work-in-progress">
      <h2>Work in Progress</h2>
      <ul>
        {% for project in workInProgress %}
        <li>
          <strong>{{ project.title }}</strong> 
          <p class="description">{{ project.description }}</p>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  </main>

  <footer>
    <p>&copy; 2026 {{ "Dhruti Davey" | formatName }}. Built with 11ty.</p>
  </footer>
</body>
</html>
